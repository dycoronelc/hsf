# =============================================================================
# Hospital Santa Fe — Variables de entorno (plantilla)
# Copie a .env en la raíz y/o backend/.env. NUNCA commitear .env con secretos.
# =============================================================================

# --- Base de datos (backend) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_santa_fe
DATABASE_SSL=false

# --- Entorno ---
NODE_ENV=development
PORT=8000

# --- URLs ---
FRONTEND_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# --- Frontend (Next.js proxy /api) ---
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Seguridad ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters

# --- Adjuntos preadmisión (backend) ---
# Por defecto: {cwd}/uploads/preadmissions
# Railway: montar volumen en /app/backend/uploads/preadmissions
# PREADMISSION_UPLOAD_DIR=/app/backend/uploads/preadmissions

# --- Correo SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hospital Santa Fe <noreply@hospitalsantafe.com>"
# En desarrollo, enviar correos reales solo si true:
SMTP_SEND_IN_DEV=false

# --- Integración Cellbyte (opcional) ---
# URL base sin /api/v1/...
# CELLBYTE_BASE_URL=http://192.168.30.41:8080/cbUat
# CELLBYTE_USERNAME=
# CELLBYTE_PASSWORD=
# Legado (opcional):
# CELLBYTE_URL=
